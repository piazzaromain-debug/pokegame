# Copie ce fichier en .env et adapte les valeurs
# Le .env ne doit JAMAIS être commité (il est dans .gitignore)

# Base de données PostgreSQL
DB_PASSWORD=pokegame_dev

# Clé secrète applicative (génère une vraie valeur en prod avec : openssl rand -hex 32)
SECRET_KEY=dev_secret_change_in_prod

# Niveau de logs backend (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
